{
  "manifest_version": 3,
  "name": "Balanz Login Autofill",
  "version": "0.1.0",
  "description": "Enables standard password manager autofill on the Balanz login page.",
  "browser_specific_settings": {
    "gecko": {
      "id": "balanz-login-autofill@local",
      "data_collection_permissions": {
        "required": ["none"]
      }
    }
  },
  "content_scripts": [
    {
      "matches": ["https://clientes.balanz.com/auth/login*"],
      "js": ["content-script.js"],
      "run_at": "document_start"
    }
  ]
}
